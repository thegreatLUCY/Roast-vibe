{
  "name": "roastvibe",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "install:frontend": "cd frontend && npm install",
    "deploy": "npm run build:frontend && wrangler deploy",
    "types": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply roastvibe --local",
    "db:migrate:remote": "wrangler d1 migrations apply roastvibe --remote",
    "reset:local": "rm -rf .wrangler/state/v3 && wrangler d1 migrations apply roastvibe --local",
    "tail": "wrangler tail"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "satori": "^0.12.0",
    "@resvg/resvg-wasm": "^2.6.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
